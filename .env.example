APP_NAME=Kiddo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_VERSION=2.0.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# Bcrypt rounds — 12 is recommended for production, 10 is fine for dev.
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=kiddo
# DB_USERNAME=root
# DB_PASSWORD=

# ─────────────────────────────────────────────────────────────
# Sessions / cache / queue
# ─────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set to "lax" or "strict" for SameSite cookie protection in prod.
SESSION_SAME_SITE=lax
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────
# Mail
# ─────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@kiddo.app"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────
# AWS (S3 storage / SES mail) — leave blank for local dev.
# ─────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────────────────────────
# Vite
# ─────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────
# Kiddo AI (OpenAI) — used by the Fox helper, Parent insights, and
# Help Center. Leave OPENAI_API_KEY empty to run the app with safe
# canned replies (the UI will display an "Offline helper" badge).
#
# Voice presets (default: alloy — cleanest articulation for first-
# graders hearing the word for the first time). Other supported
# voices: nova, shimmer, coral, sage, fable, echo, onyx — all
# selectable per-word from Admin → Words → AI voice tab.
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_FALLBACK_MODEL=tts-1-hd
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_SPEED=1.0
# Voice instructions for the per-word TTS clips. Tuned for first-grade
# pronunciation flashcards — friendly, slow, and crystal-clear.
OPENAI_TTS_INSTRUCTIONS="Speak like a warm, encouraging kindergarten teacher reading vocabulary flashcards to a six-year-old. Use a bright, friendly tone with a gentle, unhurried pace. Pronounce each phoneme clearly so the child can copy it. Add a tiny smile to the voice. Avoid robotic flatness."

# ─────────────────────────────────────────────────────────────
# Feature flags — toggle big features without code changes.
# ─────────────────────────────────────────────────────────────
KIDDO_FEATURE_FOX_HELPER=true
KIDDO_FEATURE_PARENT_AI_REPORT=true
KIDDO_FEATURE_HELP_CENTER_AI=true
