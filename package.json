{
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint resources/js --ext .js,.jsx,.ts,.tsx --max-warnings=0",
        "lint:fix": "eslint resources/js --ext .js,.jsx,.ts,.tsx --fix",
        "format": "prettier --write \"resources/{js,css}/**/*.{js,jsx,ts,tsx,css}\" \"*.{js,json,md}\"",
        "format:check": "prettier --check \"resources/{js,css}/**/*.{js,jsx,ts,tsx,css}\" \"*.{js,json,md}\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.4.0",
        "@testing-library/react": "^16.0.0",
        "@testing-library/user-event": "^14.5.2",
        "@vitejs/plugin-react": "^4.7.0",
        "@vitest/coverage-v8": "^2.1.0",
        "autoprefixer": "^10.5.0",
        "axios": "^1.7.0",
        "eslint": "^9.10.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-jsx-a11y": "^6.10.0",
        "eslint-plugin-react": "^7.36.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "globals": "^15.9.0",
        "jsdom": "^25.0.0",
        "laravel-vite-plugin": "^1.0",
        "postcss": "^8.5.13",
        "prettier": "^3.3.0",
        "prettier-plugin-tailwindcss": "^0.6.0",
        "tailwindcss": "^3.4.19",
        "vite": "^5.4.0",
        "vitest": "^2.1.0"
    },
    "dependencies": {
        "@inertiajs/react": "^3.0.3",
        "clsx": "^2.1.1",
        "framer-motion": "^12.38.0",
        "lucide-react": "^0.460.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-error-boundary": "^4.1.0",
        "react-hook-form": "^7.53.0",
        "sonner": "^1.7.0",
        "tailwind-merge": "^2.5.0",
        "zod": "^3.23.0"
    }
}
