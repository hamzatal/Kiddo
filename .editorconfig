root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[{*.json,*.jsonc,*.json5}]
indent_size = 4

[*.{js,jsx,ts,tsx,vue,css,scss,html,blade.php}]
indent_size = 4

[{package.json,*.lock}]
indent_size = 4

[Makefile]
indent_style = tab
